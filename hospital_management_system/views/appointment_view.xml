<?xml version= "1.0" encoding="UTF-8"?>

<odoo>
        <!-- Activity View For Appointment -->
    <record id="view_appointment_activity" model="ir.ui.view">
        <field name="name">view.appointment.activity</field>
        <field name="model">appointment</field>
        <field name="arch" type="xml">
            <activity string="Appointment">
                <field name="patient_id"/>
                <field name="ref"/>
                <templates>
                    <div t-name="activity-box">
                        <img t-att-src="activity_image('appointment', 'image', record.patient_id.raw_value)" t-att-title="record.patient_id.value" t-att-alt="record.patient_id.value"/>
                        <div>
                            <field name="ref" display="full"/>
                        </div>
                    </div>
                </templates>
            </activity>
        </field>
    </record>

        <!-- Tree View For Appointment -->
    <record id="view_appointment_tree" model="ir.ui.view">
        <field name="name">view.appointment.tree</field>
        <field name="model">appointment</field>
        <field name="arch" type="xml">
            <tree   decoration-success="state == 'done'"
                    decoration-warning="state == 'in_consultation'"
                    decoration-info="state == 'draft'"
                    decoration-danger="state == 'cancelled'" sample = "1" multi_edit = "1">
                <field name="patient_id" string = "Patient"/>
                <field name="gender" optional="hide"/>
                <field name="ref" optional="hide"/>
                <field name="doctor_id" widget="many2one_avatar_user"/>
                <field name="appointment_time"/>
                <field name="booking_date"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="state" widget="badge"
                        decoration-success="state == 'done'"
                        decoration-warning="state == 'in_consultation'"
                        decoration-info="state == 'draft'"
                        decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

        <!-- Form View For Appointment -->
    <record id="view_appointment_form" model="ir.ui.view">
        <field name="name">view.appointment.form</field>
        <field name="model">appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name = "action_draft" string = "Reset to Draft" type = "object" states = "draft,in_consultation"/>
                    <button name = "action_in_consultation" string = "In Consultation" type = "object" states = "draft"/>
                    <button name = "action_done" string = "Mark As Done" type = "object" states = "in_consultation"/>
                    <button name = "action_cancelled" string = "Cancelled" type = "object" states = "draft,in_consultation"/>
                    <field name = "state" nolabel = "1" widget = "statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="priority" widget="priority" class="mr-3"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="patient_id" string="Patient"/>
                            <field name="gender"/>
                            <field name="ref"/>
                            <field name="doctor_id" widget="many2one_avatar"/>
                            <field name="hide_sale_price" groups = "base.group_no_one"/>
                            <field name="appointment_time"/>
                            <field name="booking_date" help="Date of Booking" default_focus = "1"/>
                            <button name="action_test" string="Object Button" 
                            help="A message will be print on the log."
                            confirm="Are you sure to excute python code?"
                            type="object" class="oe_highlight" groups = "base.group_no_one"/>
                            <button name="%(hospital_management_system.action_patient)d" string="Action Button" 
                            help="On clicking this butto, you will be redirected to patient record."
                            confirm="Are you sure to open the patient action?"
                            type="action" class="oe_highlight" groups = "base.group_no_one"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prescription" name="prescription">
                            <field name="prescription" placeholder="Enter Your Prescription" options="{'collaborative' : true, 'resizable' : true, 'codeview' : true}"/>
                        </page>
                        <page string="Pharmacy" name="pharmacy">
                            <field name = "pharmacy_line_id">
                                <tree editable = "top">
                                    <field name = "product_id"/>
                                    <field name = "price" attrs="{'column_invisible':[('parent.hide_sale_price','=',True)]}"/>
                                    <field name = "qty"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name = "product_id"/>
                                        <field name = "price" attrs="{'column_invisible':[('parent.hide_sale_price','=',True)]}"/>
                                        <field name = "qty"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

        <!-- Search View For Appointment -->
    <record id="view_appointment_search" model="ir.ui.view">
        <field name="name">view.appointment.search</field>
        <field name="model">appointment</field>
        <field name="arch" type="xml">
            <search>
            </search>
        </field>
    </record>

    <record id = "action_appointment" model = "ir.actions.act_window">
        <field name = "name">Appointment</field>
        <field name = "type">ir.actions.act_window</field>
        <field name = "res_model">appointment</field>
        <field name = "view_mode">tree,form,activity</field>
        <field name = "context">{}</field>
        <field name = "help" type = "html">
            <p class = "o_view_nocontent_smiling_face">
                Create your first Appointment!
            </p>
        </field>
    </record>

    <menuitem id = "appointment_menu"
                name = "Appointment"
                action = "action_appointment"
                parent = "appointments_menu"
                sequence = "10"/>
</odoo>