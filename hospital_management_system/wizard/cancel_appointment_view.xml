<?xml version= "1.0" encoding="UTF-8"?>

<odoo>
        <!-- Form View For Patient Tag -->
    <record id="view_cancel_appointment_form" model="ir.ui.view">
        <field name="name">view.cancel.appointment.form</field>
        <field name="model">cancel.appointment.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="appointment_id"/>
                        <field name="reason"/>
                    </group>
                    <group>
                        <field name = "date_cancel"/>
                    </group>
                    <group>
                         <footer> 
                            <button name="action_cancel" string="Cancel Appointment" type="object" class="btn-primary"/>
                            <button special="cancel" string="Discard" class="btn-secondary"/>
                        </footer>   
                    </group>
                </group>
            </form>
        </field>
    </record>

    <record id = "action_cancel_appointment" model = "ir.actions.act_window">
        <field name = "name">Cancel Appointment</field>
        <field name = "type">ir.actions.act_window</field>
        <field name = "res_model">cancel.appointment.wizard</field>
        <field name = "view_mode">form</field>
        <field name = "target">new</field>
    </record>

    <menuitem id = "cancel_appointment_menu"
                name = "Cancel Appointment"
                action = "action_cancel_appointment"
                parent = "appointments_menu"
                sequence = "20"/>
</odoo>