<?xml version= "1.0" encoding="UTF-8"?>

<odoo>
    <!-- Sequence number for Patient -->
    <record id="sequence_patient" model="ir.sequence">
        <field name="name">Patient</field>
        <field name="code">patient</field>
        <field name="prefix">HP</field>
        <field name="padding">5</field>
        <field name="company_id" eval = "False"/>                
    </record>

    <!-- Sequence number for Appointment -->
    <record id="sequence_appointment" model="ir.sequence">
        <field name="name">Appointment</field>
        <field name="code">appointment</field>
        <field name="prefix">AP</field>
        <field name="padding">5</field>
        <field name="company_id" eval = "False"/>                
    </record>
</odoo>